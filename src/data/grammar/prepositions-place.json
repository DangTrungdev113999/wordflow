    { "type": "multiple_choice", "question": "She lives ___ 42 Nguyen Hue Street.", "options": ["in", "on", "at", "to"], "answer": 2 },
    { "type": "fill_blank", "question": "The picture is ___ the wall.", "acceptedAnswers": ["on"] },
    { "type": "fill_blank", "question": "He is waiting ___ the door.", "acceptedAnswers": ["at"] },
    { "type": "error_correction", "sentence": "The book is at the table.", "correctSentence": "The book is on the table.", "errorIndex": [3] },
    { "type": "sentence_order", "words": ["is", "the", "park", "in", "she"], "answer": "She is in the park." },
    { "type": "multiple_choice", "question": "The supermarket is ___ the bank and the school.", "options": ["under", "between", "above", "behind"], "answer": 1 },
    { "type": "fill_blank", "question": "The lamp is ___ the desk.", "acceptedAnswers": ["on", "above"] },
