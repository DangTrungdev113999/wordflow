        { "text": "under", "role": "complement", "tooltip": "Giới từ — bên dưới" },
        { "text": "the bed", "role": "object", "tooltip": "Tân ngữ" }
      ],
      "targetIndices": [0, 2]
    },
    {
      "type": "role_identify",
      "sentence": "My keys are in the bag on the table.",
      "parts": [
        { "text": "My keys", "role": "subject", "tooltip": "Chủ ngữ" },
        { "text": "are", "role": "verb", "tooltip": "Động từ tobe số nhiều" },
        { "text": "in", "role": "complement", "tooltip": "Giới từ — bên trong" },
        { "text": "the bag", "role": "object", "tooltip": "Tân ngữ" },
        { "text": "on", "role": "complement", "tooltip": "Giới từ — trên bề mặt" },
        { "text": "the table", "role": "object", "tooltip": "Tân ngữ" }
      ],
      "targetIndices": [2, 4]
    },
    {
      "type": "transform",
      "instruction": "Sửa giới từ sai thành đúng",
      "original": "She is on the classroom.",
      "acceptedAnswers": ["She is in the classroom."],
      "hint": "classroom là không gian bao quanh"
    },
    {
      "type": "transform",
      "instruction": "Sửa giới từ sai thành đúng",
      "original": "He works in his desk.",
      "acceptedAnswers": ["He works at his desk."],
      "hint": "'desk' là một điểm cụ thể, không phải không gian"
    }
  ],
  "cheatSheet": {
    "title": "Prepositions of Place",
    "formula": "Subject + be + preposition + place",
    "keyPoints": [
      "IN: không gian bao quanh (room, city, country)",
      "ON: bề mặt tiếp xúc (table, wall, floor)",
      "AT: điểm cụ thể (bus stop, door, home)"
    ],
    "signalWords": ["in the room", "on the table", "at school", "between...and", "next to", "behind", "in front of", "under", "above"],
    "commonMistakes": [
      "I live on Hanoi → I live in Hanoi",
      "The book is at the table → The book is on the table",
      "She is on the classroom → She is in the classroom"
    ]
  }
}
