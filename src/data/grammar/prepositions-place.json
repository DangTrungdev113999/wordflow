{
  "title": "Prepositions of Place",
  "level": "A1",
  "theory": {
    "sections": [
      {
        "heading": "In, On, At",
        "content": "**In:** bên trong (in the room, in the box, in Vietnam)\n**On:** trên bề mặt (on the table, on the wall, on the floor)\n**At:** tại một điểm (at school, at the door, at home)",
        "examples": [
          {
            "en": "The book is **on** the table.",
            "vi": "Quyển sách ở trên bàn."
          },
          {
            "en": "She is **in** the kitchen.",
            "vi": "Cô ấy ở trong bếp."
          },
          {
            "en": "Wait **at** the bus stop.",
            "vi": "Đợi ở trạm xe buýt."
          }
        ]
      },
      {
        "heading": "Khác",
        "content": "**Between:** giữa hai thứ\n**Next to / Beside:** bên cạnh\n**Behind:** đằng sau\n**In front of:** đằng trước\n**Under:** bên dưới\n**Above / Over:** bên trên",
        "examples": [
          {
            "en": "The bank is **between** the school and the hospital.",
            "vi": "Ngân hàng ở giữa trường học và bệnh viện."
          },
          {
            "en": "The cat is **under** the bed.",
            "vi": "Con mèo ở dưới giường."
          }
        ]
      }
    ]
  },
