{
  "id": "prepositions-place",
  "title": "Prepositions of Place",
  "level": "A1",
  "theory": {
    "sections": [
      {
        "heading": "In, On, At",
        "content": "**In:** bên trong (in the room, in the box, in Vietnam)\n**On:** trên bề mặt (on the table, on the wall, on the floor)\n**At:** tại một điểm (at school, at the door, at home)",
        "examples": [
          { "en": "The book is **on** the table.", "vi": "Quyển sách ở trên bàn." },
          { "en": "She is **in** the kitchen.", "vi": "Cô ấy ở trong bếp." },
          { "en": "Wait **at** the bus stop.", "vi": "Đợi ở trạm xe buýt." }
        ],
        "coloredExamples": [
          {
            "parts": [
              { "text": "The book", "role": "subject", "tooltip": "Chủ ngữ — vật được nói đến" },
              { "text": "is", "role": "verb", "tooltip": "Động từ tobe — chỉ vị trí" },
              { "text": "on", "role": "complement", "tooltip": "Giới từ chỉ nơi chốn — trên bề mặt" },
              { "text": "the table", "role": "object", "tooltip": "Tân ngữ — bề mặt tiếp xúc" }
            ],
            "vi": "Quyển sách ở trên bàn."
          },
          {
            "parts": [
              { "text": "She", "role": "subject", "tooltip": "Chủ ngữ — người" },
              { "text": "is", "role": "verb", "tooltip": "Động từ tobe" },
              { "text": "in", "role": "complement", "tooltip": "Giới từ — bên trong không gian" },
              { "text": "the kitchen", "role": "object", "tooltip": "Tân ngữ — không gian bao quanh" }
            ],
            "vi": "Cô ấy ở trong bếp."
          },
          {
            "parts": [
              { "text": "Wait", "role": "verb", "tooltip": "Động từ mệnh lệnh" },
              { "text": "at", "role": "complement", "tooltip": "Giới từ — tại một điểm cụ thể" },
              { "text": "the bus stop", "role": "object", "tooltip": "Tân ngữ — điểm cụ thể" }
            ],
            "vi": "Đợi ở trạm xe buýt."
          }
        ]
      },
      {
        "heading": "Khác",
        "content": "**Between:** giữa hai thứ\n**Next to / Beside:** bên cạnh\n**Behind:** đằng sau\n**In front of:** đằng trước\n**Under:** bên dưới\n**Above / Over:** bên trên",
        "examples": [
          { "en": "The bank is **between** the school and the hospital.", "vi": "Ngân hàng ở giữa trường học và bệnh viện." },
          { "en": "The cat is **under** the bed.", "vi": "Con mèo ở dưới giường." }
        ],
        "coloredExamples": [
          {
            "parts": [
              { "text": "The bank", "role": "subject", "tooltip": "Chủ ngữ" },
              { "text": "is", "role": "verb", "tooltip": "Động từ tobe" },
              { "text": "between", "role": "complement", "tooltip": "Giới từ — giữa hai vật" },
              { "text": "the school", "role": "object", "tooltip": "Vật thứ nhất" },
              { "text": "and", "role": "connector", "tooltip": "Liên từ nối hai vật" },
              { "text": "the hospital", "role": "object", "tooltip": "Vật thứ hai" }
            ],
            "vi": "Ngân hàng ở giữa trường học và bệnh viện."
          }
        ]
      }
    ]
  },
  "exercises": [
