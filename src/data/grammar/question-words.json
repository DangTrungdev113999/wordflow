{
  "id": "question-words",
  "title": "Question Words (Wh-)",
  "level": "A1",
  "cheatSheet": {
    "title": "Question Words (Wh-)",
    "formula": "Wh- word + auxiliary + S + V?",
    "keyPoints": [
      "What = cái gì, Where = ở đâu, When = khi nào, Who = ai",
      "Why = tại sao, How = như thế nào, Which = cái nào, Whose = của ai",
      "Phải có trợ động từ (do/does/did/is/are/was/were) sau từ hỏi",
      "Ngoại lệ: Who/What làm chủ ngữ thì không cần trợ động từ: Who called you?"
    ],
    "signalWords": ["what", "where", "when", "who", "why", "how", "which", "whose"],
    "commonMistakes": [
      "Thiếu trợ động từ: 'Where you live?' → 'Where do you live?'",
      "Nhầm Who/What: 'Who is your favorite color?' → 'What is your favorite color?'",
      "Sai trật tự: 'Where she does work?' → 'Where does she work?'",
      "Dùng how much/how many sai: 'How many water?' → 'How much water?'"
    ]
  },
