{
  "title": "Present Perfect Tense",
  "level": "A2",
  "theory": {
    "sections": [
      {
        "heading": "Cấu trúc",
        "content": "**Khẳng định:** S + have/has + V3 (past participle)\n**Phủ định:** S + have/has + not + V3\n**Nghi vấn:** Have/Has + S + V3?",
        "examples": [
          {
            "en": "I **have visited** Paris.",
            "vi": "Tôi đã từng đến Paris."
          },
          {
            "en": "She **hasn't finished** her homework.",
            "vi": "Cô ấy chưa hoàn thành bài tập."
          }
        ]
      },
      {
        "heading": "Cách dùng",
        "content": "1. Kinh nghiệm (ever/never)\n2. Hành động bắt đầu quá khứ, kéo dài đến hiện tại (for/since)\n3. Hành động vừa xảy ra (just, already, yet)",
        "examples": [
          {
            "en": "**Have** you **ever** been to Japan?",
            "vi": "Bạn đã bao giờ đến Nhật chưa?"
          },
          {
            "en": "I **have lived** here **for** 5 years.",
            "vi": "Tôi đã sống ở đây 5 năm."
          },
          {
            "en": "She **has just** left.",
            "vi": "Cô ấy vừa mới rời đi."
          }
        ]
      }
    ]
  },
  "exercises": [
