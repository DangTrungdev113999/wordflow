{
  "id": "present-perfect",
  "title": "Present Perfect Tense",
  "level": "A2",
  "cheatSheet": {
    "title": "Present Perfect",
    "formula": "S + have/has + V3 (past participle)",
    "keyPoints": [
      "I/You/We/They → have; He/She/It → has",
      "Kinh nghiệm: Have you ever been to Paris?",
      "Hành động bắt đầu quá khứ, kéo dài đến hiện tại: I have lived here for 5 years.",
      "Hành động vừa xảy ra: She has just left.",
      "V3 = past participle (gone, been, eaten, visited...)"
    ],
    "signalWords": ["ever", "never", "just", "already", "yet", "for", "since", "recently", "so far", "up to now"],
    "commonMistakes": [
      "'have went' → 'have gone/been' (dùng V3, không dùng V2)",
      "'has ate' → 'has eaten' (V3 bất quy tắc)",
      "'I have lived here since 5 years' → 'for 5 years' (since + mốc thời gian, for + khoảng thời gian)",
      "Nhầm với Past Simple khi có thời gian xác định: 'I have seen him yesterday' → 'I saw him yesterday'"
    ]
  },
