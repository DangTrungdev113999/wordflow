    "sections": [
      {
        "heading": "Cấu trúc",
        "content": "**Khẳng định:** S + V-ed / V2 (irregular)\n**Phủ định:** S + did not (didn't) + V\n**Nghi vấn:** Did + S + V?",
        "examples": [
          { "en": "I **visited** my grandma yesterday.", "vi": "Tôi đã thăm bà hôm qua." },
          { "en": "She **didn't go** to the party.", "vi": "Cô ấy không đi dự tiệc." },
          { "en": "**Did** you **see** the movie?", "vi": "Bạn có xem phim không?" }
        ],
        "coloredExamples": [
          {
            "parts": [
              { "text": "I", "role": "subject" },
              { "text": "visited", "role": "verb", "tooltip": "visit + ed (regular verb)" },
              { "text": "my grandma", "role": "object" },
              { "text": "yesterday", "role": "time", "tooltip": "Dấu hiệu Past Simple" }
            ],
            "vi": "Tôi đã thăm bà hôm qua."
          },
          {
            "parts": [
              { "text": "She", "role": "subject" },
              { "text": "didn't", "role": "auxiliary", "tooltip": "did + not → phủ định quá khứ" },
              { "text": "go", "role": "verb", "tooltip": "Nguyên mẫu! Không phải went" },
              { "text": "to the party", "role": "complement" }
            ],
            "vi": "Cô ấy không đi dự tiệc."
          }
        ],
        "conjugation": {
          "verb": "work / go",
          "tense": "Past Simple",
          "rows": [
            { "pronoun": "I", "affirmative": "worked / went", "negative": "didn't work / go", "question": "Did I work / go?", "highlight": "base" },
