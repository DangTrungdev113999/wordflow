  "cheatSheet": {
    "title": "Past Simple",
    "formula": "S + V-ed/V2 | S + didn't + V | Did + S + V?",
    "keyPoints": [
      "Hành động đã xảy ra và kết thúc trong quá khứ",
      "Tất cả các ngôi dùng giống nhau (không thêm -s)",
      "Phủ định & nghi vấn: didn't/Did + V nguyên mẫu"
    ],
    "signalWords": ["yesterday", "last week", "last month", "ago", "in 2020", "when I was young"],
    "commonMistakes": [
      "She didn't went → She didn't go",
      "I eated → I ate",
      "Did he went? → Did he go?"
    ]
  },
