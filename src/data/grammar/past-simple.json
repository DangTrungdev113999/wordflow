      {
        "heading": "Regular vs Irregular",
        "content": "**Regular:** thêm -ed (worked, played, studied)\n**Irregular:** dạng riêng (go→went, eat→ate, see→saw, buy→bought)",
        "examples": [
          { "en": "We **played** football yesterday.", "vi": "Chúng tôi chơi bóng đá hôm qua." },
          { "en": "He **went** to Japan last year.", "vi": "Anh ấy đi Nhật năm ngoái." }
        ],
        "coloredExamples": [
          {
            "parts": [
              { "text": "He", "role": "subject" },
              { "text": "went", "role": "verb", "tooltip": "go → went (irregular)" },
              { "text": "to Japan", "role": "complement" },
              { "text": "last year", "role": "time", "tooltip": "Dấu hiệu Past Simple" }
            ],
            "vi": "Anh ấy đi Nhật năm ngoái."
          }
        ]
      },
      {
        "heading": "Dấu hiệu nhận biết",
        "content": "yesterday, last week/month/year, ago, in 2020, when I was young",
        "examples": [
          { "en": "I **met** her two years **ago**.", "vi": "Tôi gặp cô ấy hai năm trước." },
          { "en": "**Last summer**, we **traveled** to Da Nang.", "vi": "Mùa hè trước, chúng tôi đi Đà Nẵng." }
        ]
      }
    ]
