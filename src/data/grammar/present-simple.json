                "vi": "Cô ấy làm việc mỗi ngày."
              },
              {
                "parts": [
                  { "text": "They", "role": "subject", "tooltip": "Số nhiều → giữ nguyên V" },
                  { "text": "play", "role": "verb", "tooltip": "Giữ nguyên, không thêm -s" },
                  { "text": "football", "role": "object", "tooltip": "Tân ngữ" },
                  { "text": "on Sundays", "role": "time", "tooltip": "Hàng tuần → Present Simple" }
