  "cheatSheet": {
    "title": "Present Simple",
    "formula": "S + V(s/es) | S + don't/doesn't + V | Do/Does + S + V?",
    "keyPoints": [
      "Diễn tả thói quen, sự thật, lịch trình cố định",
      "Ngôi 3 số ít (He/She/It): V thêm -s/-es",
      "Phủ định & nghi vấn: động từ luôn nguyên mẫu"
    ],
    "signalWords": ["always", "usually", "often", "sometimes", "rarely", "never", "every day", "every week"],
    "commonMistakes": [
      "He don't → He doesn't",
      "She doesn't likes → She doesn't like",
      "Does he works? → Does he work?"
    ]
  },
