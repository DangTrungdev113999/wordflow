{
  "id": "past-continuous",
  "title": "Past Continuous Tense",
  "level": "A2",
  "cheatSheet": {
    "title": "Past Continuous",
    "formula": "S + was/were + V-ing",
    "keyPoints": [
      "I/He/She/It → was; You/We/They → were",
      "Diễn tả hành động đang xảy ra tại một thời điểm trong quá khứ",
      "Hai hành động xảy ra đồng thời: While S + was/were + V-ing, S + was/were + V-ing",
      "Hành động đang xảy ra bị gián đoạn: S + was/were + V-ing + when + S + V(past simple)"
    ],
    "signalWords": ["at that time", "while", "when", "at 8 PM last night", "all day yesterday", "at this time yesterday"],
    "commonMistakes": [
      "'He were playing' → 'He was playing' (I/He/She/It dùng was)",
      "'They was dancing' → 'They were dancing' (You/We/They dùng were)",
      "Quên thêm -ing: 'was play' → 'was playing'",
      "Nhầm với Past Simple khi diễn tả hành động đang diễn ra"
    ]
  },
