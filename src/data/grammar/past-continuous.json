{
  "title": "Past Continuous Tense",
  "level": "A2",
  "theory": {
    "sections": [
      {
        "heading": "Cấu trúc",
        "content": "**Khẳng định:** S + was/were + V-ing\n**Phủ định:** S + was/were + not + V-ing\n**Nghi vấn:** Was/Were + S + V-ing?",
        "examples": [
          {
            "en": "I **was reading** a book.",
            "vi": "Tôi đang đọc sách."
          },
          {
            "en": "They **were playing** football.",
            "vi": "Họ đang chơi bóng đá."
          }
        ]
      },
      {
        "heading": "Cách dùng",
        "content": "1. Hành động đang xảy ra tại một thời điểm trong quá khứ\n2. Hai hành động xảy ra đồng thời\n3. Hành động đang xảy ra thì bị gián đoạn",
        "examples": [
          {
            "en": "While I **was cooking**, he **was watching** TV.",
            "vi": "Trong khi tôi nấu ăn, anh ấy xem TV."
          },
          {
            "en": "I **was sleeping** when the phone **rang**.",
            "vi": "Tôi đang ngủ thì điện thoại reo."
          }
        ]
      }
    ]
  },
  "exercises": [
    {
