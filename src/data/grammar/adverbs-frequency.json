{
  "title": "Adverbs of Frequency",
  "level": "A1",
  "theory": {
    "sections": [
      {
        "heading": "Trạng từ chỉ tần suất",
        "content": "**always** (100%) > **usually** (80%) > **often** (60%) > **sometimes** (40%) > **rarely** (10%) > **never** (0%)\n\nVị trí: trước động từ thường, sau be/aux",
        "examples": [
          {
            "en": "I **always** drink coffee in the morning.",
            "vi": "Tôi luôn uống cà phê buổi sáng."
          },
          {
            "en": "She is **never** late.",
            "vi": "Cô ấy không bao giờ trễ."
          },
          {
            "en": "They **sometimes** go to the cinema.",
            "vi": "Họ thỉnh thoảng đi xem phim."
          }
        ]
      }
    ]
  },
