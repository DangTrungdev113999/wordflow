{
  "id": "imperative",
  "title": "Imperative Sentences",
  "level": "A1",
  "theory": {
    "sections": [
      {
        "heading": "Câu mệnh lệnh",
        "content": "Dùng V nguyên thể (không chủ ngữ)\n**Khẳng định:** V + ...\n**Phủ định:** Don't + V + ...\nDùng để: ra lệnh, yêu cầu, hướng dẫn, khuyên bảo",
        "examples": [
          {
            "en": "**Open** the door, please.",
            "vi": "Xin hãy mở cửa."
          },
          {
            "en": "**Don't** touch that!",
            "vi": "Đừng chạm vào đó!"
          },
          {
            "en": "**Turn** left at the traffic light.",
            "vi": "Rẽ trái ở đèn giao thông."
          }
        ]
      }
    ]
  },
