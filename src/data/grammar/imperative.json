{
  "id": "imperative",
  "title": "Imperative Sentences",
  "level": "A1",
  "cheatSheet": {
    "title": "Imperative Sentences (Câu mệnh lệnh)",
    "formula": "V + ... (khẳng định) | Don't + V + ... (phủ định)",
    "keyPoints": [
      "Không có chủ ngữ — bắt đầu bằng động từ nguyên thể",
      "Phủ định: Don't + V (KHÔNG dùng 'Not + V')",
      "Dùng để: ra lệnh, yêu cầu, hướng dẫn, khuyên bảo, mời",
      "Thêm 'please' để lịch sự hơn"
    ],
    "signalWords": [
      "please",
      "don't",
      "let's",
      "be careful",
      "stop",
      "listen"
    ],
    "commonMistakes": [
      "Not talk in class. → Don't talk in class. (dùng Don't, không dùng Not)",
      "Don't to be late. → Don't be late. (không dùng 'to' sau Don't)",
      "You open the door. → Open the door. (câu mệnh lệnh không có chủ ngữ)"
    ]
  },
  "theory": {
    "sections": [
      {
        "heading": "Câu mệnh lệnh",
        "content": "Dùng V nguyên thể (không chủ ngữ)\n**Khẳng định:** V + ...\n**Phủ định:** Don't + V + ...\nDùng để: ra lệnh, yêu cầu, hướng dẫn, khuyên bảo",
