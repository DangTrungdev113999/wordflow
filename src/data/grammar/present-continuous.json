  "cheatSheet": {
    "title": "Present Continuous",
    "formula": "S + am/is/are + V-ing",
    "keyPoints": [
      "Hành động đang xảy ra ngay lúc nói",
      "Tình huống tạm thời (this week, this month)",
      "Kế hoạch tương lai gần đã sắp xếp"
    ],
    "signalWords": ["now", "right now", "at the moment", "currently", "look!", "listen!"],
    "commonMistakes": [
      "He is play → He is playing",
      "She are cooking → She is cooking",
      "I studying → I am studying"
    ]
  },
  "exercises": [
    {
      "type": "multiple_choice",
      "question": "She ___ dinner right now.",
