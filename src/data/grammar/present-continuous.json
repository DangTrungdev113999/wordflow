      {
        "heading": "Dấu hiệu nhận biết",
        "content": "now, right now, at the moment, currently, look!, listen!",
        "examples": [
          { "en": "**Listen!** Someone **is singing**.", "vi": "Nghe kìa! Ai đó đang hát." },
          { "en": "**At the moment**, I **am reading** a book.", "vi": "Hiện tại, tôi đang đọc sách." }
        ]
      }
