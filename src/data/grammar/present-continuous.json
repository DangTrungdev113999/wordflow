      {
        "heading": "Cách dùng",
        "content": "1. Hành động đang xảy ra ngay lúc nói\n2. Hành động tạm thời\n3. Kế hoạch đã sắp xếp trong tương lai gần",
        "examples": [
          { "en": "Look! It **is raining**.", "vi": "Nhìn kìa! Trời đang mưa." },
          { "en": "I **am living** with my friend this month.", "vi": "Tháng này tôi đang sống với bạn." },
          { "en": "We **are meeting** tomorrow at 3 PM.", "vi": "Chúng tôi sẽ gặp nhau lúc 3h chiều mai." }
        ],
        "coloredExamples": [
          {
            "parts": [
              { "text": "Look!", "role": "connector", "tooltip": "Dấu hiệu Present Continuous" },
              { "text": "It", "role": "subject" },
              { "text": "is", "role": "auxiliary" },
              { "text": "raining", "role": "verb", "tooltip": "Đang xảy ra ngay lúc nói" }
            ],
            "vi": "Nhìn kìa! Trời đang mưa."
          }
