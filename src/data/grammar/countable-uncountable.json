{
  "id": "countable-uncountable",
  "title": "Countable & Uncountable Nouns",
  "level": "A2",
  "theory": {
    "sections": [
      {
        "heading": "Danh từ đếm được",
        "content": "Có thể đếm: a book, two cats, three apples\nDùng **a/an** với số ít, **some/many/few** với số nhiều",
        "examples": [
          {
            "en": "I have **three** books.",
            "vi": "Tôi có ba quyển sách."
          },
          {
            "en": "There are **many** students.",
            "vi": "Có nhiều học sinh."
          }
        ]
      },
      {
        "heading": "Danh từ không đếm được",
        "content": "Không thể đếm: water, rice, money, information\nDùng **some/much/little**, KHÔNG dùng a/an",
        "examples": [
          {
            "en": "I need **some** water.",
            "vi": "Tôi cần chút nước."
          },
          {
            "en": "There is **much** traffic today.",
            "vi": "Hôm nay có nhiều xe cộ."
          }
        ]
      }
    ]
  },
  "exercises": [
    {
      "type": "multiple_choice",
      "question": "Can I have ___ water?",
      "options": [
        "a",
        "an",
        "some",
        "many"
      ],
      "answer": 2
    },
    {
      "type": "multiple_choice",
      "question": "There are ___ apples on the table.",
      "options": [
        "much",
        "a",
        "some",
        "a lot"
      ],
      "answer": 2
    },
    {
