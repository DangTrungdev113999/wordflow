  "cheatSheet": {
    "title": "Prepositions of Time",
    "formula": "Subject + verb + at/in/on + time expression",
    "keyPoints": [
      "IN: tháng, năm, mùa, buổi (in March, in 2024, in winter, in the morning)",
      "ON: ngày, thứ, ngày lễ cụ thể (on Monday, on July 4th, on my birthday)",
      "AT: giờ, thời điểm cụ thể, đêm (at 3 PM, at noon, at night, at Christmas)"
    ],
    "signalWords": ["in the morning", "on Monday", "at 6 AM", "in 2024", "on my birthday", "at night", "in summer"],
    "commonMistakes": [
      "I will see you at Monday → I will see you on Monday",
      "She was born at 1995 → She was born in 1995",
      "He arrived in 9 o'clock → He arrived at 9 o'clock"
    ]
  }
