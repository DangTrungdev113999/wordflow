{
  "id": "there-is-are",
  "title": "There is / There are",
  "level": "A1",
  "cheatSheet": {
    "title": "There is / There are",
    "formula": "There is + singular noun / There are + plural noun",
    "keyPoints": [
      "There is + danh từ số ít hoặc không đếm được",
      "There are + danh từ số nhiều",
      "Phủ định: There isn't / There aren't",
      "Nghi vấn: Is there...? / Are there...?",
      "There is thường viết tắt: There's"
    ],
    "signalWords": ["a", "an", "some", "any", "many", "much", "a lot of", "no"],
    "commonMistakes": [
      "'There are a book' → 'There is a book' (a book = số ít → is)",
      "'There is many cars' → 'There are many cars' (many cars = số nhiều → are)",
      "Nhầm 'There' với 'Their' hoặc 'They're'",
      "'It has a park' → 'There is a park' (dùng There is/are để nói về sự tồn tại)"
    ]
  },
