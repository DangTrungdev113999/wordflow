{
  "id": "future-simple",
  "title": "Future Simple (will)",
  "level": "A2",
  "theory": {
    "sections": [
      {
        "heading": "Cấu trúc",
        "content": "**Khẳng định:** S + will + V\n**Phủ định:** S + will not (won't) + V\n**Nghi vấn:** Will + S + V?",
        "examples": [
          {
            "en": "I **will help** you.",
            "vi": "Tôi sẽ giúp bạn."
          },
          {
            "en": "She **won't come** tomorrow.",
            "vi": "Cô ấy sẽ không đến ngày mai."
          }
        ]
      },
      {
        "heading": "Cách dùng",
        "content": "1. Quyết định tức thì\n2. Dự đoán\n3. Lời hứa, đề nghị",
        "examples": [
          {
            "en": "It **will rain** later.",
            "vi": "Lát nữa trời sẽ mưa."
          },
          {
            "en": "I **will call** you tonight.",
            "vi": "Tôi sẽ gọi cho bạn tối nay."
          }
        ]
      }
    ]
  },
  "exercises": [
    {
