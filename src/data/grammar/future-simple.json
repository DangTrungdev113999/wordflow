  "title": "Future Simple (will)",
  "level": "A2",
  "cheatSheet": {
    "title": "Future Simple (will)",
    "formula": "S + will + V (nguyên thể) | S + won't + V | Will + S + V?",
    "keyPoints": [
      "Luôn dùng động từ nguyên thể sau will (KHÔNG chia)",
      "Phủ định: will not = won't",
      "Dùng cho: quyết định tức thì, dự đoán, lời hứa, đề nghị",
      "Không dùng 'will' trong mệnh đề if (first conditional)"
    ],
    "signalWords": [
      "tomorrow",
      "next week/month/year",
      "soon",
      "later",
      "I think",
      "probably",
      "in the future"
    ],
    "commonMistakes": [
      "She will goes → She will go (sau will luôn là V nguyên thể)",
      "They won't to come → They won't come (không dùng 'to' sau won't)",
      "Will she comes? → Will she come? (V nguyên thể trong câu hỏi)"
    ]
  },
