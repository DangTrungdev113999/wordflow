    "sections": [
      {
        "heading": "Tính từ sở hữu",
        "content": "**my, your, his, her, its, our, their**\nĐặt trước danh từ",
        "examples": [
          { "en": "This is **my** book.", "vi": "Đây là sách của tôi." },
          { "en": "**Their** house is big.", "vi": "Nhà của họ rất lớn." }
        ],
        "coloredExamples": [
          {
            "parts": [
              { "text": "This", "role": "subject", "tooltip": "Chủ ngữ — đại từ chỉ định" },
              { "text": "is", "role": "verb", "tooltip": "Động từ tobe" },
              { "text": "my", "role": "determiner", "tooltip": "Tính từ sở hữu — của tôi" },
              { "text": "book", "role": "object", "tooltip": "Tân ngữ — vật được sở hữu" }
            ],
            "vi": "Đây là sách của tôi."
          },
          {
            "parts": [
              { "text": "Their", "role": "determiner", "tooltip": "Tính từ sở hữu — của họ" },
              { "text": "house", "role": "subject", "tooltip": "Chủ ngữ — vật được sở hữu" },
              { "text": "is", "role": "verb", "tooltip": "Động từ tobe" },
              { "text": "big", "role": "complement", "tooltip": "Bổ ngữ — tính từ mô tả" }
            ],
            "vi": "Nhà của họ rất lớn."
          }
        ]
      },
      {
        "heading": "Sở hữu cách ('s)",
        "content": "Thêm **'s** sau danh từ để chỉ sở hữu\nDanh từ số nhiều tận cùng -s: chỉ thêm **'**",
        "examples": [
          { "en": "**John's** car is new.", "vi": "Xe của John mới." },
          { "en": "The **students'** books are on the desk.", "vi": "Sách của các học sinh ở trên bàn." }
        ],
        "coloredExamples": [
          {
            "parts": [
              { "text": "John's", "role": "determiner", "tooltip": "Sở hữu cách — của John" },
              { "text": "car", "role": "subject", "tooltip": "Chủ ngữ — vật được sở hữu" },
              { "text": "is", "role": "verb", "tooltip": "Động từ tobe" },
              { "text": "new", "role": "complement", "tooltip": "Bổ ngữ — tính từ" }
            ],
            "vi": "Xe của John mới."
          }
        ]
      }
    ]
  },
