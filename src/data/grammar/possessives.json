{
  "id": "possessives",
  "title": "Possessives",
  "level": "A1",
  "theory": {
    "sections": [
      {
        "heading": "Tính từ sở hữu",
        "content": "**my, your, his, her, its, our, their**\nĐặt trước danh từ",
        "examples": [
          {
            "en": "This is **my** book.",
            "vi": "Đây là sách của tôi."
          },
          {
            "en": "**Their** house is big.",
            "vi": "Nhà của họ rất lớn."
          }
        ]
      },
      {
        "heading": "Sở hữu cách ('s)",
        "content": "Thêm **'s** sau danh từ để chỉ sở hữu\nDanh từ số nhiều tận cùng -s: chỉ thêm **'**",
        "examples": [
          {
            "en": "**John's** car is new.",
            "vi": "Xe của John mới."
          },
          {
            "en": "The **students'** books are on the desk.",
            "vi": "Sách của các học sinh ở trên bàn."
          }
        ]
      }
    ]
  },
