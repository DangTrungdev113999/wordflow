      "acceptedAnswers": ["This is my book."],
      "hint": "'mine' là đại từ sở hữu, trước danh từ dùng 'my'"
    },
    {
      "type": "transform",
      "instruction": "Chuyển sang dùng sở hữu cách ('s)",
      "original": "The car of Tom is red.",
      "acceptedAnswers": ["Tom's car is red."],
      "hint": "Dùng 's thay vì 'of' cho người"
    }
  ],
  "cheatSheet": {
    "title": "Possessives",
    "formula": "possessive adjective + noun / noun + 's + noun",
    "keyPoints": [
      "Tính từ sở hữu: my, your, his, her, its, our, their + danh từ",
      "Sở hữu cách: thêm 's sau danh từ chỉ người (John's car)",
      "Số nhiều tận cùng -s: chỉ thêm ' (the students' books)"
    ],
    "signalWords": ["my", "your", "his", "her", "its", "our", "their", "'s"],
    "commonMistakes": [
      "This is mine book → This is my book",
      "Her go to school → She goes to school",
      "The car of Tom → Tom's car"
    ]
  }
