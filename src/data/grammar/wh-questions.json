{
  "id": "wh-questions",
  "title": "Wh- Questions Structure",
  "level": "A1",
  "theory": {
    "sections": [
      {
        "heading": "Cấu trúc câu hỏi Wh-",
        "content": "**Wh + auxiliary + S + V?**\nWhat do you want?\nWhere does she live?\nWhy did they leave?\n\n**Wh làm chủ ngữ:** Who + V?\nWho made this? (Ai làm cái này?)",
        "examples": [
          {
            "en": "**What does** she want?",
            "vi": "Cô ấy muốn gì?"
          },
          {
            "en": "**Who** called you?",
            "vi": "Ai gọi cho bạn?"
          }
        ]
      }
    ]
  },
  "exercises": [
    {
