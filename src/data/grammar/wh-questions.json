{
  "id": "wh-questions",
  "title": "Wh- Questions Structure",
  "level": "A1",
  "cheatSheet": {
    "title": "Wh- Questions Structure",
    "formula": "Wh- word + auxiliary + S + V (base form)?",
    "keyPoints": [
      "Trợ động từ (do/does/did) phải đứng trước chủ ngữ",
      "Động từ chính luôn ở dạng nguyên thể khi có trợ động từ",
      "Ngoại lệ: Wh- làm chủ ngữ → Who/What + V (không cần trợ động từ)",
      "Với be/have: Wh + be/have + S + ...?"
    ],
    "signalWords": ["what", "where", "when", "who", "why", "how", "which", "whose", "how many", "how much"],
    "commonMistakes": [
      "'What does she wants?' → 'What does she want?' (có does thì V nguyên thể)",
      "'Where she does work?' → 'Where does she work?' (sai trật tự S và aux)",
      "'Who did called?' → 'Who called?' (Who làm chủ ngữ không cần did)",
      "'How many water?' → 'How much water?' (water không đếm được)"
    ]
  },
  "theory": {
    "sections": [
      {
        "heading": "Cấu trúc câu hỏi Wh-",
        "content": "**Wh + auxiliary + S + V?**\nWhat do you want?\nWhere does she live?\nWhy did they leave?\n\n**Wh làm chủ ngữ:** Who + V?\nWho made this? (Ai làm cái này?)",
        "examples": [
          {
            "en": "**What does** she want?",
            "vi": "Cô ấy muốn gì?"
          },
