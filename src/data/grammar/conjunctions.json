{
  "title": "Conjunctions: And, But, Or, So, Because",
  "level": "A1",
  "theory": {
    "sections": [
      {
        "heading": "Liên từ cơ bản",
        "content": "**And:** và (thêm thông tin)\n**But:** nhưng (tương phản)\n**Or:** hoặc (lựa chọn)\n**So:** nên (kết quả)\n**Because:** bởi vì (nguyên nhân)",
        "examples": [
          {
            "en": "I like tea **and** coffee.",
            "vi": "Tôi thích trà và cà phê."
          },
          {
            "en": "She is tired **but** happy.",
            "vi": "Cô ấy mệt nhưng vui."
          },
          {
            "en": "I stayed home **because** it was raining.",
            "vi": "Tôi ở nhà vì trời mưa."
          }
        ]
      }
    ]
  },
  "exercises": [
    {
      "type": "multiple_choice",
      "question": "I was hungry ___ I ate a sandwich.",
      "options": [
        "but",
        "and",
        "so",
        "because"
      ],
      "answer": 2
    },
    {
