{
  "id": "modals",
  "title": "Modal Verbs: Can, Must, Should",
  "level": "A2",
  "cheatSheet": {
    "title": "Modal Verbs",
    "formula": "S + can/must/should + V (bare infinitive)",
    "keyPoints": [
      "Modal verbs are always followed by the base form of the verb (no 'to', no '-s')",
      "Can = ability / permission, Must = obligation / prohibition, Should = advice",
      "Negative: can't, mustn't, shouldn't",
      "Questions: invert modal and subject — Can you...? Must we...? Should I...?"
    ],
    "signalWords": ["can", "can't", "must", "mustn't", "should", "shouldn't"],
    "commonMistakes": [
      "Adding 'to' after modal: 'must to go' → 'must go'",
      "Adding '-s' to verb: 'can speaks' → 'can speak'",
      "Using 'don't' for negation: 'don't must' → 'mustn't'",
      "Confusing 'mustn't' (prohibition) with 'don't have to' (no obligation)"
    ]
  },
